{
  "name": "calendars",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start": "vite preview",
    "lint": "eslint .",
    "build-theme": "cunningham -g css,scss,ts -o src/styles && mv src/styles/cunningham-tokens.scss src/styles/cunningham-tokens-sass.scss",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:update": "vitest run --update",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "routes:generate": "tsr generate",
    "prebuild": "npm run routes:generate",
    "prets:check": "npm run routes:generate",
    "ts:check": "tsc --noEmit",
    "analyze": "ANALYZE=1 vite build"
  },
  "engines": {
    "node": "24.x",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@event-calendar/core": "5.5.1",
    "@gouvfr-lasuite/cunningham-react": "4.2.0",
    "@gouvfr-lasuite/ui-kit": "0.19.10",
    "@tanstack/react-query": "5.90.21",
    "@tanstack/react-router": "1.170.8",
    "@tanstack/react-router-devtools": "1.167.0",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "i18next": "25.8.14",
    "i18next-browser-languagedetector": "8.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "16.5.6",
    "react-toastify": "11.0.5",
    "sass": "1.97.3",
    "ts-ics": "2.4.3"
  },
  "devDependencies": {
    "@gouvfr-lasuite/cunningham-tokens": "3.1.0",
    "@tanstack/router-cli": "1.167.13",
    "@tanstack/router-plugin": "1.168.11",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/ui": "4.1.8",
    "eslint": "9.30.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "jsdom": "27.4.0",
    "rollup-plugin-visualizer": "7.0.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.0",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  }
}
